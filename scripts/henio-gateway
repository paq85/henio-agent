#!/usr/bin/env python3
"""Canonical Henio gateway launcher.

Keeps the legacy ``scripts/henio-gateway`` implementation as the shared
compatibility backend while providing a Henio-first entrypoint.
"""

from pathlib import Path
import runpy

if __name__ == "__main__":
    legacy_script = Path(__file__).with_name("henio-gateway")
    runpy.run_path(str(legacy_script), run_name="__main__")
